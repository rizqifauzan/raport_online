# Salin file ini menjadi .env.local lalu isi nilainya.
# .env.local tidak ikut ter-commit (lihat .gitignore).

# Connection string dari project Neon (Dashboard Neon → Connection Details).
# Gunakan yang "Pooled connection" bila tersedia.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require

# Kunci rahasia untuk menandatangani cookie sesi login.
# Buat string acak panjang, mis: openssl rand -base64 32
SESSION_SECRET=ganti-dengan-string-acak-panjang

# Kredensial admin awal (dibuat saat `npm run seed`).
ADMIN_USERNAME=admin
ADMIN_PASSWORD=ganti-password-ini
